# Backend API host URL
# ⚠️ PRODUCTION: Always use HTTPS (e.g., https://api.example.com)
# ❌ NEVER use HTTP in production - credentials will be exposed!
# 
# 💡 TIP: For local development, you can omit the scheme:
#   - localhost:19091 → automatically uses http://localhost:19091
#   - api.example.com → automatically uses https://api.example.com
# 
# Explicit scheme always takes precedence if provided.
NEXT_PUBLIC_API_HOST=

# ⚠️ SECURITY WARNING: NEXT_PUBLIC_* variables are exposed to the browser!
# Do not use these for storing actual secrets, API keys, or authentication tokens.
# Backend-only secrets must be stored server-side (e.g., Vault, Secrets Manager)
# or injected to server runtime (not exposed to client bundles).

# RECOMMENDATION: Backend should rely solely on session-token for user authentication.
# If you need server-to-server API keys, keep them out of NEXT_PUBLIC_* and
# access them only from server-side code or a secure proxy.